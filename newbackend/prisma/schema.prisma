// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TECH_MASTER
  SUPER_ADMIN
  MANAGER
  MASTER      // New: Level 1 Agent
  AGENT       // New: Level 2 Agent
  USER
}

model User {
  id          Int      @id @default(autoincrement())
  email       String?  @unique
  phoneNumber String?  @unique
  password    String
  username    String?  @unique
  firstName   String?
  lastName    String?
  city        String?
  role        Role     @default(USER)
  onesignalPlayerId String?  // OneSignal player/subscription ID for push notifications
  currency    String?  @default("INR")
  country     String?   // ISO-2 country code set at registration — no default so unset = not India
  isBanned    Boolean  @default(false)
  bonus_id    String?
  balance     Float    @default(0)
  exposure    Float    @default(0)
  fiatBonus   Float    @default(0)  // INR bonus wallet — legacy aggregate (for backward compat)
  cryptoBonus Float    @default(0)  // USD bonus wallet — legacy aggregate (for backward compat)
  casinoBonus Float    @default(0)  // INR casino-only bonus wallet
  sportsBonus Float    @default(0)  // INR sports-only bonus wallet
  cryptoBalance Float  @default(0)  // USD main wallet — funded by NOWPayments crypto deposits
  activeWallet  String @default("fiat")  // "fiat" | "crypto" — persisted active wallet selection
  // Bonus wagering tracking (fast access fields — mirrors active UserBonus)
  wageringRequired Float @default(0)  // Total bonus wagering required (bonusAmount × Nx)
  wageringDone     Float @default(0)  // Bonus wagering done so far
  // Per-type bonus wagering (casino vs sports tracked separately)
  casinoBonusWageringRequired Float @default(0)
  casinoBonusWageringDone     Float @default(0)
  sportsBonusWageringRequired Float @default(0)
  sportsBonusWageringDone     Float @default(0)
  // Deposit wagering lock (1x deposit must be wagered before withdrawal allowed)
  depositWageringRequired Float @default(0)  // Set on deposit approval: depositAmount × multiplier
  depositWageringDone     Float @default(0)  // Incremented on every bet placed
  // Totals for analytics
  totalDeposited   Float @default(0)  // Sum of all confirmed deposits
  totalWagered     Float @default(0)  // Sum of all bets placed (sports + casino)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  casinoTransactions CasinoTransaction[]
  transactions Transaction[]
  notifications Notification[]
  // bets relation removed as Bet is now in MongoDB

  // Referral System
  referralCode    String?  @unique
  referrerId      Int?
  referrer        User?    @relation("UserReferrals", fields: [referrerId], references: [id])
  referrals       User[]   @relation("UserReferrals")
  referralHistoryGiven ReferralHistory[] @relation("ReferrerRelation")
  referralHistoryReceived ReferralHistory[] @relation("ReferredRelation")

  // Agent Hierarchy System
  agentId         Int?
  agent           User?    @relation("UserAgent", fields: [agentId], references: [id])
  agentUsers      User[]   @relation("UserAgent")

  masterId        Int?
  master          User?    @relation("UserMaster", fields: [masterId], references: [id])
  masterUsers     User[]   @relation("UserMaster")

  managerId       Int?
  manager         User?    @relation("UserManager", fields: [managerId], references: [id])
  managedUsers    User[]   @relation("UserManager")

  partnershipSettings Json?  // [{ sport_id: '4', partnership: 10 }]

  // KYC & Responsible Gambling
  kycStatus       KycStatus @default(NONE)
  kycDocuments    KycDocument[]
  depositLimit    Float?
  lossLimit       Float?
  selfExclusionUntil DateTime?

  // Support
  supportTickets  SupportTicket[]

  // Zeero Originals
  minesGames                 MinesGame[]
  originalsSessions          OriginalsSession[]
  originalsEngagementEvents  OriginalsEngagementEvent[]

  // VIP
  vipTier         VipTier   @default(NONE)
  vipApplication  VipApplication?

  // Bonus
  userBonuses     UserBonus[]

  // Password Reset
  passwordResetTokens PasswordResetToken[]
}


enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

model KycDocument {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // ID_CARD, PASSPORT, PROOF_OF_ADDRESS
  url       String
  status    KycStatus @default(PENDING)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model CasinoTransaction {
  id          Int      @id @default(autoincrement())
  txn_id      String   @unique
  user_id     Int
  username    String
  amount      Float
  type        String   // debit, credit, refund
  provider    String
  game_code   String
  game_name   String?  // human-readable name looked up from CasinoGame
  round_id    String?
  wallet_type String   @default("fiat") // "fiat" | "crypto"
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

model Transaction {
  id              Int      @id @default(autoincrement())
  userId          Int
  amount          Float
  type            String   // DEPOSIT, WITHDRAWAL
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  paymentMethod   String?
  paymentDetails  Json?
  transactionId   String?  @unique // unique transaction id from payment gateway or manual reference
  proof           String?
  utr             String?  @unique
  adminId         Int?     // Admin who approved/rejected
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model HomeCategory {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  image       String?
  link        String
  isLarge     Boolean  @default(false)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReferralReward {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  conditionType  String   // SIGNUP, DEPOSIT_FIRST, DEPOSIT_RECURRING, BET_Volume
  conditionValue Float    @default(0) // Minimum deposit/bet amount to trigger
  rewardType     String   // FIXED, PERCENTAGE
  rewardAmount   Float    // Fixed amount or percentage value
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referralHistory ReferralHistory[]
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String   // UPI, BANK, CRYPTO
  type      String   // DEPOSIT, WITHDRAWAL
  minAmount Float
  maxAmount Float
  fee       Float    @default(0)
  feeType   String   @default("PERCENTAGE") // PERCENTAGE, FIXED
  isActive  Boolean  @default(true)
  details   Json?    // Bank details or wallet address
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferralHistory {
  id                  Int      @id @default(autoincrement())
  referrerId          Int
  referredUserId      Int
  rewardId            Int?
  sourceTransactionId String?  @unique // deposit/bet txn key — unique constraint prevents double-credit
  amount              Float
  status              String   @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  referrer            User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referredUser        User     @relation("ReferredRelation", fields: [referredUserId], references: [id])
  reward              ReferralReward? @relation(fields: [rewardId], references: [id])
}

model SupportTicket {
  id        Int      @id @default(autoincrement())
  userId    Int
  status    String   @default("OPEN") // OPEN, CLOSED
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  messages  SupportMessage[]
}

model SupportMessage {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  sender    String   // 'USER' or 'ADMIN'
  message   String
  createdAt DateTime @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  action    String   // 'UPDATE_USER', 'APPROVE_WITHDRAWAL', etc.
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ─── VIP System ─────────────────────────────────────────────────────────────
enum VipTier {
  NONE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum VipStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  TRANSFER_REQUESTED
}

model VipApplication {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique  // One active application per user
  user             User      @relation(fields: [userId], references: [id])
  status           VipStatus @default(PENDING)

  // User-submitted info
  message          String?   @db.Text // Why they want VIP
  currentPlatform  String?            // Platform they have VIP at (transfer)
  platformUsername String?            // Their username there
  monthlyVolume    Float?             // Self-reported monthly volume

  // Admin review
  reviewedBy       Int?               // Admin userId
  reviewNotes      String?  @db.Text  // Internal notes
  reviewedAt       DateTime?
  assignedTier     VipTier?           // Tier assigned on approval

  // Security metadata
  ipAddress        String?
  userAgent        String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  deepLink  String?  // deep link URL e.g. "zeero://match/12345/4"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model PushNotification {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  imageUrl    String?
  deepLink    String?           // e.g. "zeero://match/12345/4"
  segment     String?           // ALL, VIP, NEW, ACTIVE, CHURNED
  targetUserIds Int[]           // specific user IDs (empty = all in segment)
  sentBy      Int               // admin user ID
  sentCount   Int      @default(0)
  onesignalId String?           // OneSignal notification ID from response
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ─── Bonus Wagering Tracking ─────────────────────────────────────────────────
enum BonusStatus {
  ACTIVE
  PENDING_CONVERSION
  COMPLETED
  FORFEITED
  EXPIRED
}

model UserBonus {
  id               Int         @id @default(autoincrement())
  userId           Int
  user             User        @relation(fields: [userId], references: [id])
  bonusId          String      // MongoDB ObjectId of the Bonus template
  bonusCode        String      // Promo code used
  bonusTitle       String      // Snapshot of bonus title
  bonusCurrency    String      @default("INR")  // 'INR' | 'CRYPTO' | 'BOTH' — which bonus wallet this targets
  applicableTo     String      @default("BOTH") // 'CASINO' | 'SPORTS' | 'BOTH' — which bets count for wagering
  depositAmount    Float       // Deposit that triggered the bonus
  bonusAmount      Float       // Bonus credited
  wageringRequired Float       // Total stake required (bonusAmount × wageringReq)
  wageringDone     Float       @default(0)
  status           BonusStatus @default(ACTIVE)
  isEnabled        Boolean     @default(false)  // user must explicitly select bonus for betting
  expiresAt        DateTime?
  completedAt      DateTime?
  forfeitedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model EventLock {
  id          Int      @id @default(autoincrement())
  eventId     String   
  betType     String   // "ODDS" | "FANCY"
  userBlocks  Int[]    // Array of blocked user IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([eventId, betType])
}

/// Persistent queue for Diamond API /post-market calls that failed after all retries.
/// A cron job retries these until success, then marks them DONE and stores the API response.
model DiamondPostQueue {
  id           Int      @id @default(autoincrement())
  sportsid     Int
  gmid         String
  marketName   String
  mname        String
  gtype        String
  attempts     Int      @default(0)   // total attempts made so far
  status       String   @default("PENDING")  // PENDING | DONE | FAILED
  lastError    String?
  apiResponse  Json?    // successful response body stored here
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}


/// One-time token for password reset emails. Expires after 1 hour.
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ─── Zeero Originals: Mines Game ─────────────────────────────────────────────
enum MinesGameStatus {
  ACTIVE
  CASHEDOUT
  LOST
}

model MinesGame {
  id              Int             @id @default(autoincrement())
  userId          Int
  user            User            @relation(fields: [userId], references: [id])
  betAmount       Float
  mineCount       Int             // 1–24
  status          MinesGameStatus @default(ACTIVE)

  // Provably fair seeds
  serverSeed      String          // stored in plain, shown after game ends
  serverSeedHash  String          // SHA-256 of serverSeed shown before game starts
  clientSeed      String          @default("zeero")
  nonce           Int             @default(0)

  // Game state (persisted so sessions can reconnect)
  minePositions   Int[]           // tile indices 0–24; revealed only after game ends
  revealedTiles   Int[]           // tile indices the player has clicked so far

  // Outcome
  multiplier      Float           @default(1.0)
  payout          Float           @default(0)

  // Wallet support
  walletType      String          @default("fiat")   // "fiat" | "crypto"
  usedBonus       Boolean         @default(false)     // whether bet came from bonus wallet
  bonusAmount     Float           @default(0)         // bonus portion of bet

  currency        String          @default("INR")

  // GGR engine audit (internal, never exposed to clients)
  biasWeight      Float           @default(0)         // bias applied at game start
  engagementFlags Json?                               // e.g. { nearMiss: true, streak: 3 }

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── Zeero Originals: Admin Config per Game ──────────────────────────────────
enum EngagementMode {
  OFF
  SOFT
  AGGRESSIVE
}

enum OriginalsEngagementEventType {
  NEAR_MISS
  WIN_STREAK
  LOSS_STREAK
  BIG_WIN
  COMEBACK
}

model OriginalsConfig {
  id                  Int            @id @default(autoincrement())
  gameKey             String         @unique            // 'mines' | 'crash' | 'dice'
  isActive            Boolean        @default(true)
  maintenanceMode     Boolean        @default(false)
  maintenanceMessage  String?

  // Bet limits
  minBet              Float          @default(10)
  maxBet              Float          @default(100000)
  maxWin              Float          @default(1000000)  // absolute max payout

  // House edge & multiplier cap
  houseEdgePercent    Float          @default(1.0)      // base house edge %
  maxMultiplier       Float          @default(500.0)

  // GGR control — house revenue %
  // e.g. 70 means house keeps 70% of all wagered (RTP = 30%)
  targetGgrPercent    Float          @default(5.0)      // admin-set house revenue target %
  ggrWindowHours      Int            @default(24)       // rolling window for GGR tracking
  ggrBiasStrength     Float          @default(0.20)     // max probability bias (0..1)

  // Per-user GGR overrides (optional JSON map userId→targetGgr)
  perUserGgrOverrides Json?

  // Engagement system
  engagementMode      EngagementMode @default(SOFT)
  nearMissEnabled     Boolean        @default(true)
  bigWinThreshold     Float          @default(10.0)     // payout/bet ratio to trigger big-win event
  streakWindow        Int            @default(5)        // consecutive games to detect streak

  // Display info
  displayRtpPercent   Float          @default(95.0)     // shown to users (informational only)

  // Home page display (Cloudflare Images URL set by admin)
  thumbnailUrl        String?                           // Cloudflare Images URL
  gameName            String?                           // Display name (e.g. "Zeero Mines")
  gameDescription     String?                           // Short description shown on home card
  fakePlayerMin       Int            @default(200)      // min of random "playing now" count
  fakePlayerMax       Int            @default(300)      // max of random "playing now" count

  // Audit
  updatedBy           Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([gameKey])
}

model OriginalsGGRSnapshot {
  id            Int      @id @default(autoincrement())
  gameKey       String
  windowStart   DateTime
  windowEnd     DateTime
  totalWagered  Float    @default(0)
  totalPaidOut  Float    @default(0)
  totalGames    Int      @default(0)
  totalWins     Int      @default(0)
  totalLosses   Int      @default(0)
  // GGR = (wagered - paidOut) / wagered * 100
  ggrPercent    Float    @default(0)
  snapshotAt    DateTime @default(now())

  @@index([gameKey, windowStart])
  @@index([snapshotAt])
}

model OriginalsSession {
  id            Int      @id @default(autoincrement())
  gameKey       String
  userId        Int
  socketId      String
  gameId        Int?
  connectedAt   DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  isActive      Boolean  @default(true)
  user          User     @relation(fields: [userId], references: [id])

  @@index([gameKey])
  @@index([userId])
  @@index([isActive])
}

model OriginalsEngagementEvent {
  id          Int                           @id @default(autoincrement())
  gameKey     String
  userId      Int
  gameId      Int
  eventType   OriginalsEngagementEventType
  metadata    Json?                          // { multiplier, streak, nearMissTile }
  createdAt   DateTime                      @default(now())
  user        User                          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([gameKey])
  @@index([eventType])
}

// ─── SMS OTP ─────────────────────────────────────────────────────────────────
/// Short-lived OTP codes delivered via LAAFFIC SMS API.
/// purpose: "REGISTER" | "FORGOT_PASSWORD"
model PhoneOtp {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  code        String
  purpose     String   // "REGISTER" | "FORGOT_PASSWORD"
  expiresAt   DateTime
  used        Boolean  @default(false)
  attempts    Int      @default(0)  // failed verify attempts; invalidated after 5
  createdAt   DateTime @default(now())

  @@index([phoneNumber, purpose])
  @@index([expiresAt])
}

// ─── Email OTP ───────────────────────────────────────────────────────────────
/// Short-lived OTP codes delivered via Email API.
/// purpose: "REGISTER" | "FORGOT_PASSWORD"
model EmailOtp {
  id          Int      @id @default(autoincrement())
  email       String
  code        String
  purpose     String   // "REGISTER" | "FORGOT_PASSWORD" | "BIND_EMAIL"
  expiresAt   DateTime
  used        Boolean  @default(false)
  attempts    Int      @default(0)  // failed verify attempts; invalidated after 5
  createdAt   DateTime @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

// ─── Chatwoot Integration ────────────────────────────────────────────────────

model ChatwootConfig {
  id              Int       @id @default(autoincrement())
  instanceUrl     String    // e.g. https://chat.zeero.bet
  apiToken        String    // Chatwoot user/admin API access token
  accountId       Int       // Chatwoot account ID
  agentBotToken   String?   // Agent bot access token
  webhookSecret   String?   // Secret to validate incoming webhooks
  autoSyncUsers   Boolean   @default(false)
  defaultInboxId  Int?      // Default inbox to use for bot
  isEnabled       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Chatbot Automation System ──────────────────────────────────────────────

model ChatbotProfile {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  avatar          String?
  personality     String?
  tone            String    @default("professional")
  responseDelay   Int       @default(1000)
  typingIndicator Boolean   @default(true)
  isEnabled       Boolean   @default(true)
  workingHoursOnly Boolean  @default(false)
  workingHoursStart String?
  workingHoursEnd   String?
  workingTimezone   String?
  channels        ChatbotChannelConfig[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ChatbotChannelConfig {
  id          Int       @id @default(autoincrement())
  botId       Int
  channel     String
  isEnabled   Boolean   @default(true)
  priority    Int       @default(0)
  settings    Json?
  bot         ChatbotProfile @relation(fields: [botId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([botId, channel])
}

// ─── Knowledge Base ─────────────────────────────────────────────────────────

model KnowledgeCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  parentId    Int?
  parent      KnowledgeCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    KnowledgeCategory[] @relation("CategoryTree")
  articles    KnowledgeArticle[]
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KnowledgeArticle {
  id          Int       @id @default(autoincrement())
  title       String
  content     String    @db.Text
  categoryId  Int?
  category    KnowledgeCategory? @relation(fields: [categoryId], references: [id])
  tags        String[]
  priority    Int       @default(0)
  isPublished Boolean   @default(true)
  version     Int       @default(1)
  metadata    Json?
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  versions    KnowledgeArticleVersion[]

  @@index([categoryId])
  @@index([isPublished])
}

model KnowledgeArticleVersion {
  id          Int       @id @default(autoincrement())
  articleId   Int
  article     KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title       String
  content     String    @db.Text
  version     Int
  changedBy   Int?
  createdAt   DateTime  @default(now())

  @@index([articleId])
}

// ─── Intents & Entities ─────────────────────────────────────────────────────

model ChatbotIntent {
  id                  Int       @id @default(autoincrement())
  name                String    @unique
  displayName         String
  description         String?
  category            String?
  confidenceThreshold Float     @default(0.7)
  isEnabled           Boolean   @default(true)
  priority            Int       @default(0)
  trainingPhrases     ChatbotTrainingPhrase[]
  responses           ChatbotResponseTemplate[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([category])
  @@index([isEnabled])
}

model ChatbotTrainingPhrase {
  id        Int       @id @default(autoincrement())
  intentId  Int
  intent    ChatbotIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
  phrase    String
  language  String    @default("en")
  createdAt DateTime  @default(now())

  @@index([intentId])
}

model ChatbotEntity {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  displayName String
  type        String
  pattern     String?
  values      Json?
  synonyms    ChatbotSynonym[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChatbotSynonym {
  id        Int       @id @default(autoincrement())
  entityId  Int
  entity    ChatbotEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  value     String
  synonyms  String[]
  createdAt DateTime  @default(now())

  @@index([entityId])
}

// ─── Response Templates ─────────────────────────────────────────────────────

model ChatbotResponseTemplate {
  id            Int       @id @default(autoincrement())
  name          String
  intentId      Int?
  intent        ChatbotIntent? @relation(fields: [intentId], references: [id])
  content       String    @db.Text
  contentType   String    @default("text")
  richMedia     Json?
  language      String    @default("en")
  conditions    Json?
  abTestGroup   String?
  isEnabled     Boolean   @default(true)
  priority      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([intentId])
  @@index([isEnabled])
}

// ─── Auto-Reply Rules ───────────────────────────────────────────────────────

model ChatbotAutoReplyRule {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  conditionType String
  conditionValue Json
  responseTemplateId Int?
  responseText  String?   @db.Text
  responseRich  Json?
  priority      Int       @default(0)
  isEnabled     Boolean   @default(true)
  isFallback    Boolean   @default(false)
  scheduleStart DateTime?
  scheduleEnd   DateTime?
  channels      String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isEnabled, priority])
}

// ─── Quick Replies / Canned Responses ───────────────────────────────────────

model ChatbotQuickReplySet {
  id          Int       @id @default(autoincrement())
  name        String
  category    String?
  shortcode   String?   @unique
  replies     ChatbotQuickReply[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChatbotQuickReply {
  id          Int       @id @default(autoincrement())
  setId       Int
  set         ChatbotQuickReplySet @relation(fields: [setId], references: [id], onDelete: Cascade)
  label       String
  content     String    @db.Text
  sortOrder   Int       @default(0)
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([setId])
}

// ─── Conversation Flows ─────────────────────────────────────────────────────

model ChatbotFlow {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  triggerType String
  triggerValue Json?
  isPublished Boolean   @default(false)
  isDraft     Boolean   @default(true)
  version     Int       @default(1)
  nodes       Json
  variables   Json?
  channels    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  versions    ChatbotFlowVersion[]
}

model ChatbotFlowVersion {
  id        Int       @id @default(autoincrement())
  flowId    Int
  flow      ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version   Int
  nodes     Json
  variables Json?
  changedBy Int?
  createdAt DateTime  @default(now())

  @@index([flowId])
}

model ChatbotFlowTemplate {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  category    String
  nodes       Json
  variables   Json?
  createdAt   DateTime  @default(now())
}

// ─── User Segment Targeting ─────────────────────────────────────────────────

model ChatbotUserSegment {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  conditions  Json
  botConfigOverrides Json?
  autoReplyOverrides Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChatbotUserBlacklist {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  reason    String?
  createdAt DateTime  @default(now())
}

model ChatbotUserWhitelist {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  reason    String?
  createdAt DateTime  @default(now())
}

// ─── Escalation ─────────────────────────────────────────────────────────────

model ChatbotEscalationRule {
  id              Int       @id @default(autoincrement())
  name            String
  triggerType     String
  triggerConfig   Json
  routeTo         String?
  priorityLevel   String    @default("normal")
  slaMinutes      Int?
  isEnabled       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Greeting / Welcome ─────────────────────────────────────────────────────

model ChatbotGreeting {
  id            Int       @id @default(autoincrement())
  name          String
  greetingType  String
  channel       String
  content       String    @db.Text
  richMedia     Json?
  conditions    Json?
  isEnabled     Boolean   @default(true)
  priority      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Automation Workflows ───────────────────────────────────────────────────

model ChatbotWorkflow {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  triggerType   String
  triggerConfig Json
  actions       Json
  conditions    Json?
  isEnabled     Boolean   @default(true)
  schedule      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── A/B Tests ──────────────────────────────────────────────────────────────

model ChatbotABTest {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  variants      Json
  status        String    @default("draft")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
