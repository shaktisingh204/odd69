{
  "name": "newbackend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rm -rf dist tsconfig.build.tsbuildinfo",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "backfill:bonus-wallets": "ts-node src/scripts/backfill-bonus-wallets.ts",
    "backfill:bonus-minimums": "ts-node src/scripts/backfill-bonus-minimums.ts",
    "backfill:missed-deposit-bonuses": "ts-node src/scripts/backfill-missed-deposit-bonuses.ts",
    "repair:bonus-user468": "ts-node src/scripts/repair-orphaned-bonus-user468.ts",
    "repair:sports-bonus-transactions": "ts-node src/scripts/repair-sports-bonus-transactions.ts",
    "repair:sportradar-settlements": "ts-node src/scripts/revert-sportradar-settlements.ts",
    "repair:sportradar-settlements:force": "ts-node src/scripts/revert-sportradar-settlements.ts --apply --allow-negative",
    "repair:bonus-convert-recovery": "ts-node src/scripts/repair-bonus-convert-recovery.ts",
    "repair:stabilize-wallets": "ts-node src/scripts/stabilize-repaired-wallets.ts",
    "repair:wallet-history": "ts-node src/scripts/repair-wallet-history.ts",
    "repair:wallet-history:force": "ts-node src/scripts/repair-wallet-history.ts --apply --allow-negative",
    "repair:wallets-to-cutoff": "ts-node src/scripts/rebuild-wallets-to-cutoff.ts",
    "repair:wallets-to-cutoff:force": "ts-node src/scripts/rebuild-wallets-to-cutoff.ts --apply --allow-negative"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.17.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/websockets": "^11.1.13",
    "@prisma/client": "5.22.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "csv-parse": "^6.1.0",
    "form-data": "^4.0.5",
    "ioredis": "^5.9.2",
    "mongoose": "^9.2.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
